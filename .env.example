# Rain Market Creator - Environment Variables

# The Graph API Key (for transaction history, analytics, charts)
# Get one at: https://thegraph.com/studio/
GRAPH_API_KEY=your_graph_api_key_here

# WebSocket RPC URL (for live price feeds and events)
# Use Alchemy, Infura, or any Arbitrum One WSS endpoint
WS_RPC_URL=wss://arb-mainnet.g.alchemy.com/v2/YOUR_KEY

# Note: These are optional for basic functionality
# Markets, positions, and basic trading work without them
# You only need them for:
# - GRAPH_API_KEY: Transaction history, P&L, leaderboards, charts
# - WS_RPC_URL: Live WebSocket price/event feeds
